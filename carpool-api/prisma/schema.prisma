generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // or your preferred provider
  url      = env("DATABASE_URL")
}

// =============================
// Core Models: Address & Person
// =============================

model Address {
  // this may be replaced by a Google Maps (or similar) address for routing purposes
  id     Int    @id @default(autoincrement())
  street String
  city   String
  state  String
  zip    String

  // Inverse relation – people with this address
  people Person[]

  @@unique([street, city, state, zip], name: "street_city_state_zip") // Ensure unique address entries
}

model Person {
  // Person model to represent individuals
  id        Int     @id @default(autoincrement())
  name      String
  addressId Int
  address   Address @relation(fields: [addressId], references: [id])

  // One-to-one optional extensions
  parent Parent?
  child  Child?
}

// =============================
// Family (Account) Model
// =============================

model Family {
  // Represents a family account with multiple members (parents and children)
  id          Int     @id @default(autoincrement())
  clerkUserId String  @unique // Unique identifier for the clerk user
  phone       String? @unique // Optional phone number for the account

  // All parents and children in this family account
  parents  Parent[]
  children Child[]
}

// =============================
// Profile Models: Parent and Child
// =============================

model Parent {
  id       Int    @id @default(autoincrement())
  personId Int    @unique
  person   Person @relation(fields: [personId], references: [id])

  // Link to the family account
  familyId Int
  family   Family @relation(fields: [familyId], references: [id])

  // Contact & capacity info
  email String @unique
  phone String // Individual phone number if needed
  seats Int // Number of seats available if driving

  // Memberships: registrations into carpool groups
  memberships ParentMembership[]

  // As a driver for a Carpool
  drivingCarpools Carpool[]
}

model Child {
  id       Int    @id @default(autoincrement())
  personId Int    @unique
  person   Person @relation(fields: [personId], references: [id])

  // Link to the family account
  familyId Int
  family   Family @relation(fields: [familyId], references: [id])

  boosterSeat Boolean
  frontSeat   Boolean

  // Memberships: registrations into carpool groups
  memberships ChildMembership[]

  // Optionally, a Child can be assigned to a Carpool
  carpoolId Int?
  carpool   Carpool? @relation(fields: [carpoolId], references: [id])
}

// =============================
// Carpool Groups, Trip Times, and Carpools
// =============================

model CarpoolGroup {
  /**
   * Represents a carpool group for parents and children to register into
   * Each group contains all parents and children that will be divided into carpool rides
   * Each group has a set of trip times that are available for parents and children to select
   */
  id   Int    @id @default(autoincrement())
  name String @unique // Unique name for the carpool group

  // Trip times set by the admin at group creation
  tripTimes TripTime[]

  // Group memberships (registrations) for parents and children
  parentMemberships ParentMembership[]
  childMemberships  ChildMembership[]

  // Organized Carpools for this group
  carpools Carpool[]

  createdAt DateTime @default(now()) // tracking when the group was created
}

model TripTime {
  /**
   * Represents a specific time slot for a carpool group
   * Each group can have multiple trip times, and each time can be selected by multiple parents/children
   */
  id    Int    @id @default(autoincrement())
  label String // e.g., "Monday morning", "Thursday evening"

  // TripTime is defined for a specific CarpoolGroup
  carpoolGroupId Int
  carpoolGroup   CarpoolGroup @relation(fields: [carpoolGroupId], references: [id])

  // Inverse many-to-many: which ParentMemberships selected this time
  parentMemberships ParentMembership[] @relation("ParentTripTimeAvailability")
  // Inverse many-to-many: which ChildMemberships selected this time
  childMemberships  ChildMembership[]  @relation("ChildTripTimeAvailability")

  @@unique([carpoolGroupId, label], name: "one_label_per_group") // Ensure unique trip time labels within a group
}

model Carpool {
  /**
   * This is a carpool ride instance containing one driver and multiple passengers
   * Many of these carpool rides together form a carpool group
   */
  id             Int          @id @default(autoincrement())
  carpoolGroupId Int
  carpoolGroup   CarpoolGroup @relation(fields: [carpoolGroupId], references: [id])

  // The driver for this carpool (a Parent)
  driverId Int
  driver   Parent @relation(fields: [driverId], references: [id])

  // Child passengers for this carpool ride
  passengers Child[]

  @@unique([carpoolGroupId, driverId], name: "one_carpool_per_driver_per_group") // Ensure one driver per carpool per ride
}

// =============================
// Membership Join Tables for CarpoolGroup Registrations
// =============================

model ParentMembership {
  /**
   * Represents a parent who has registered into a carpool group
   * This allows for multiple parents per group and multiple groups per parent
   */
  id             Int          @id @default(autoincrement())
  parentId       Int
  parent         Parent       @relation(fields: [parentId], references: [id])
  carpoolGroupId Int
  carpoolGroup   CarpoolGroup @relation(fields: [carpoolGroupId], references: [id])
  isAdmin        Boolean      @default(false) // Whether this parent is an admin of the group

  // The trip times (from the group's available options) that the parent selects
  selectedTripTimes TripTime[] @relation("ParentTripTimeAvailability")

  @@unique([parentId, carpoolGroupId])
}

model ChildMembership {
  /**
   * Represents a child who has registered into a carpool group
   * This allows for multiple children per group and multiple groups per child
   */
  id             Int          @id @default(autoincrement())
  childId        Int
  child          Child        @relation(fields: [childId], references: [id])
  carpoolGroupId Int
  carpoolGroup   CarpoolGroup @relation(fields: [carpoolGroupId], references: [id])

  // The trip times (from the group's available options) that the child selects
  selectedTripTimes TripTime[] @relation("ChildTripTimeAvailability")

  @@unique([childId, carpoolGroupId])
}
